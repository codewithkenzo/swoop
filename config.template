# Swoop Backend Configuration Template
# Copy this file to .env and customize the values for your environment

# Database Configuration
DATABASE_URL=postgresql://swoop_user:swoop_password@localhost:5432/swoop

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
CORS_ORIGIN=http://localhost:5173

# Storage Configuration
STORAGE_TYPE=postgres  # Options: postgres, sqlite, memory
SQLITE_PATH=./data/swoop.db

# AI/ML Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vector Database Configuration
VECTOR_DB_URL=postgresql://swoop_user:swoop_password@localhost:5432/swoop

# Monitoring Configuration
METRICS_ENABLED=true
PROMETHEUS_PORT=9090
LOG_LEVEL=info

# Document Processing Configuration
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,txt,html,md,doc,docx

# Crawling Configuration
MAX_CRAWL_DEPTH=3
CRAWL_DELAY_MS=1000
MAX_CONCURRENT_CRAWLS=10
USER_AGENT=Swoop/1.0 (+https://github.com/yourusername/swoop)

# Chat Configuration
CHAT_HISTORY_LIMIT=100
CHAT_RESPONSE_TIMEOUT_SECONDS=30

# Security Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Development Configuration
DEBUG=true
RUST_LOG=info 